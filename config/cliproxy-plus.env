# CLIProxyAPIPlus Configuration
# ==============================================================================
# These values are the repository defaults.
# They are intentionally committed in plaintext for direct deployment.
# ==============================================================================

# Shared host preparation
SWAP_SIZE_GB=2

# Default image tag
CLIPROXY_IMAGE=docker.io/eceasy/cli-proxy-api-plus:latest

# HTTP API listen port
CLIPROXY_PORT=8317

# Use host networking so localhost-only management checks still work on the host
CLIPROXY_NETWORK_MODE=host

# Container memory limit
CLIPROXY_MEMORY_LIMIT=384M

# Management API bearer key used by lifecycle scripts and local maintenance
CLIPROXY_MANAGEMENT_KEY=gaoyx123
CLIPROXY_MANAGEMENT_ALLOW_REMOTE=true

# Default API key for local /v1/* calls
CLIPROXY_API_KEY=gaoyx123

# Enable in-memory usage statistics so backup/restore has data to export
CLIPROXY_USAGE_STATISTICS_ENABLED=true

# Keep pprof disabled unless you are troubleshooting locally
CLIPROXY_PPROF_ENABLE=false
CLIPROXY_PPROF_ADDR=127.0.0.1:8316
