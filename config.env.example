# Proxy Configuration
# ==============================================================================
# These values are examples, not safe production defaults.
# Change credentials before exposing the service to the public internet.
# ==============================================================================

# --- System Configuration ---
# Swap size in GB (Prevent OOM on small VPS)
SWAP_SIZE_GB=2

# --- Proxy User Configuration ---
# Username and Password for SOCKS5/HTTP/Trojan
PROXY_USER=admin
PROXY_PASS=change_me_before_public_use

# UUID for VLESS (User ID)
# [AUTO-FILL] Leave EMPTY. The script will generate a secure random UUID for you.
VLESS_UUID=

# --- Network Configuration ---
# Base port for proxies. Ports used: 10000, 10001, 10002, 10003, 10004
BASE_PORT=10000

# Shadowsocks Encryption (AEAD)
# Method: chacha20-ietf-poly1305 (Recommended for mobile)
SS_METHOD=chacha20-ietf-poly1305
SS_PASSWORD=change_me_ss_password

# --- Reality Configuration (Stealth) ---
# Target website to mimic (Must support TLS 1.3/H2)
REALITY_DEST=www.microsoft.com:443
REALITY_SERVER_NAMES=www.microsoft.com,microsoft.com

# Reality Keys (X25519)
# [AUTO-FILL] Leave these EMPTY. The install script will generate them for you.
# Only fill these if you are migrating existing keys.
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=

# --- Sing-box Configuration ---
# Pin the image tag so deployments are repeatable.
SING_BOX_IMAGE=ghcr.io/sagernet/sing-box:v1.13.2

# Enable compatibility flags required by the current generated config when using
# sing-box v1.13.x. Disable only after validating newer config/image behavior.
ENABLE_DEPRECATED_SING_BOX_FLAGS=true

# Memory limit for the container
MEMORY_LIMIT=256M
